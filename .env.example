# PostgreSQL connection string
DATABASE_URL=postgresql://<username>:<password>@<host>:5432/<database>

# JWT secret key for authentication
JWT_SECRET=<random secret>

# Backend port
PORT=8000

# Frontend API URL pointing to the backend
VITE_API_URL=http://localhost:8000

# OpenAI API key for embedding and querying
OPENAI_API_KEY=<your OpenAI API key>

# Google Generative AI SDK key for answering questions
ANTHROPIC_API_KEY=<your Anthropic API key>

# Pinecone API key (if applicable for vector storage, not used here)
PINECONE_API_KEY=<your Pinecone API key>

# Hugging Face cache directory (mounted as a volume in Docker)
HUGGINGFACE_CACHE_DIR=/root/.cache/huggingface